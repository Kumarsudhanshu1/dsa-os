#include <stdio.h>

int findPeakIndex(int arr[], int size) {
    for (int i = 0; i < size - 1; i++) {
        if (arr[i] > arr[i + 1]) {
            return i;
        }
    }
    return size - 1;
}

void sortArray(int arr[], int size) {
    for (int i = 0; i < size - 1; i++) {
        for (int j = 0; j < size - i - 1; j++) {
            if (arr[j] > arr[j + 1]) {
                int temp = arr[j];
                arr[j] = arr[j + 1];
                arr[j + 1] = temp;
            }
        }
    }
}

int main() {
    int arr[] = {1, 3, 5, 7, 6, 4, 2};
    int size = sizeof(arr) / sizeof(arr[0]);   // Corrected

    int peakIdx = findPeakIndex(arr, size);

    printf("Peak index: %d\n", peakIdx);

    sortArray(arr, size);

    printf("Sorted array: {");
    for (int i = 0; i < size; i++) {
        printf("%d%s", arr[i], (i == size - 1) ? "" : ", ");
    }
    printf("}\n");

    return 0;
}